{
  "info": {
    "name": "DisWebTienda",
    "description": "Colección de endpoints para la tienda digital de libros electrónicos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Salud",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Verifica el estado del servidor"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Autenticación",
      "item": [
        {
          "name": "Registro Cliente",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/registro",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "registro"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Pérez\",\n  \"telefono\": \"999888777\",\n  \"direccion\": \"Av. Principal 123\",\n  \"email\": \"juan@email.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Registra un nuevo cliente"
          },
          "response": []
        },
        {
          "name": "Registro Proveedor",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/registro-proveedor",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "registro-proveedor"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Editorial\",\n  \"apellido\": \"ABC\",\n  \"telefono\": \"999888777\",\n  \"direccion\": \"Calle Falsa 456\",\n  \"email\": \"contacto@editorial-abc.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Registra un nuevo proveedor"
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.session && jsonData.session.access_token) {",
                  "    pm.collectionVariables.set('token', jsonData.session.access_token);",
                  "    console.log('Token guardado:', jsonData.session.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@email.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Inicia sesión y guarda el token automáticamente"
          },
          "response": []
        },
        {
          "name": "Solicitar Reset Password",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "reset-password"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@email.com\"\n}"
            },
            "description": "Envía email para restablecer contraseña"
          },
          "response": []
        },
        {
          "name": "Obtener Perfil",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/perfil",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "perfil"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "description": "Obtiene el perfil del usuario autenticado"
          },
          "response": []
        },
        {
          "name": "Actualizar Perfil",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/auth/perfil",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "perfil"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Carlos\",\n  \"apellido\": \"Pérez\",\n  \"telefono\": \"999888777\",\n  \"direccion\": \"Av. Principal 123, Lima\"\n}"
            },
            "description": "Actualiza el perfil del usuario autenticado"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Usuarios (CRUD)",
      "item": [
        {
          "name": "Listar Usuarios",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/usuarios",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "description": "Lista todos los usuarios (requiere admin o super)"
          },
          "response": []
        },
        {
          "name": "Obtener Usuario por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios", "{{userId}}"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "description": "Obtiene un usuario por su ID"
          },
          "response": []
        },
        {
          "name": "Actualizar Usuario",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios", "{{userId}}"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Carlos\",\n  \"apellido\": \"Pérez Updated\",\n  \"telefono\": \"999888777\",\n  \"direccion\": \"Nueva dirección 789\",\n  \"rol\": \"cliente\"\n}"
            },
            "description": "Actualiza un usuario por ID"
          },
          "response": []
        },
        {
          "name": "Eliminar Usuario",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios", "{{userId}}"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "description": "Elimina un usuario por ID (no se puede eliminar super)"
          },
          "response": []
        }
      ]
    }
  ]
}
